/**
 * Tests for badge count calculation and management
 * Ensures badge correctly reflects all pending sources (in-memory + stored interactions)
 * Prevents regression of stale badge issue where stored interactions were ignored
 */

import assert from 'node:assert/strict';
import { describe, it, beforeEach } from 'node:test';
import { AgentInteractionProvider } from './webviewProvider';
import { initializeChatHistoryStorage } from '../storage/chatHistoryStorage';
import * as vscode from 'vscode';

// Note: These are integration-style tests that verify the badge calculation logic
// They use the actual AgentInteractionProvider methods to ensure real behavior

describe('AgentInteractionProvider - Badge Count Management', () => {
    let provider: AgentInteractionProvider;
    let mockContext: vscode.ExtensionContext;

    beforeEach(() => {
        // Note: These tests require a proper VS Code extension context
        // In a real test environment, you would mock vscode.ExtensionContext
        mockContext = {
            extensionUri: vscode.Uri.parse('file:///test'),
            globalState: {
                get: () => [],
                update: () => Promise.resolve(),
            },
            workspaceState: {
                get: () => [],
                update: () => Promise.resolve(),
            },
        } as unknown as vscode.ExtensionContext;

        // Initialize storage
        initializeChatHistoryStorage(mockContext);
        
        // Create provider instance
        provider = new AgentInteractionProvider(mockContext);
    });

    describe('_getTotalPendingCount() - calculates total from all sources', () => {
        it('should return 0 when no pending items exist', () => {
            const count = (provider as any)._getTotalPendingCount();
            assert.strictEqual(count, 0);
        });

        it('should count only in-memory requests when no stored interactions exist', async () => {
            // Create 2 pending in-memory requests
            const promise1 = (provider as any).waitForUserResponse('Question 1?', 'Test 1');
            const promise2 = (provider as any).waitForUserResponse('Question 2?', 'Test 2');

            const count = (provider as any)._getTotalPendingCount();
            assert.strictEqual(count, 2);

            // Cleanup
            promise1.catch(() => {});
            promise2.catch(() => {});
        });

        it('should count pending plan reviews from storage', () => {
            // Mock storage with 2 pending plan reviews
            const pendingReviews: StoredInteraction[] = [
                {
                    id: 'review_1',
                    type: 'plan_review',
                    timestamp: Date.now(),
                    title: 'Review 1',
                    plan: 'Plan content',
                    status: 'pending',
                },
                {
                    id: 'review_2',
                    type: 'plan_review',
                    timestamp: Date.now(),
                    title: 'Review 2',
                    plan: 'Plan content 2',
                    status: 'pending',
                },
            ];

            mockStorage = provider.getChatHistoryStorage();
            mock.fn(() => pendingReviews);

            const count = (provider as any)._getTotalPendingCount();
            // Should include storage pending interactions
            assert.strictEqual(count >= 2, true);
        });

        it('should count pending whiteboards from storage', () => {
            // Mock storage with 1 pending whiteboard
            const pendingWhiteboards: StoredInteraction[] = [
                {
                    id: 'wb_1',
                    type: 'whiteboard',
                    timestamp: Date.now(),
                    title: 'Whiteboard 1',
                    whiteboardSession: {
                        id: 'wb_1',
                        interactionId: 'wb_1',
                        context: 'Test context',
                        canvases: [],
                        status: 'pending',
                    },
                },
            ];

            mockStorage = provider.getChatHistoryStorage();
            mock.fn(() => pendingWhiteboards);

            const count = (provider as any)._getTotalPendingCount();
            // Should include storage pending whiteboards
            assert.strictEqual(count >= 1, true);
        });

        it('should sum all sources: in-memory + plan reviews + whiteboards', async () => {
            // Create 1 in-memory request
            const promise1 = (provider as any).waitForUserResponse('Question?', 'Test');

            const count = (provider as any)._getTotalPendingCount();
            // Should have at least the in-memory request
            assert.strictEqual(count >= 1, true);

            // Cleanup
            promise1.catch(() => {});
        });
    });

    describe('_setBadge() - updates badge correctly', () => {
        it('should set badge value when count > 0', () => {
            (provider as any)._setBadge(3);
            
            assert.strictEqual(mockView.badge?.value, 3);
            assert.strictEqual(mockView.badge?.tooltip, 'Input required');
        });

        it('should clear badge to 0 first when count becomes 0', () => {
            (provider as any)._setBadge(0);
            
            // Should set to 0 first (workaround for VS Code API)
            assert.strictEqual(mockView.badge?.value, 0);
        });

        it('should remove badge entirely after delay when all sources are empty', async () => {
            (provider as any)._setBadge(0);
            
            // Wait for the setTimeout to execute
            await new Promise(resolve => setTimeout(resolve, 150));
            
            // Badge should be undefined (completely removed)
            assert.strictEqual(mockView.badge, undefined);
        });

        it('should keep badge when storage has pending items even if in-memory is empty', async () => {
            // This test verifies the fix: badge should NOT clear if stored interactions exist
            (provider as any)._setBadge(0);
            
            await new Promise(resolve => setTimeout(resolve, 150));
            
            // If there are stored pending interactions, badge should not be undefined
            // The implementation checks _getTotalPendingCount() which includes storage
            const totalPending = (provider as any)._getTotalPendingCount();
            if (totalPending > 0) {
                assert.notStrictEqual(mockView.badge, undefined);
            }
        });
    });

    describe('Badge updates on state changes', () => {
        it('should update badge when in-memory request is created', async () => {
            const initialCount = (provider as any)._getTotalPendingCount();
            
            // Create a new request
            const promise = (provider as any).waitForUserResponse('New question?', 'Test');
            
            const newCount = (provider as any)._getTotalPendingCount();
            assert.strictEqual(newCount, initialCount + 1);
            
            // Cleanup
            promise.catch(() => {});
        });

        it('should update badge when in-memory request is cancelled', async () => {
            // Create a request
            const promise = (provider as any).waitForUserResponse('Question?', 'Test');
            const countWithRequest = (provider as any)._getTotalPendingCount();
            
            // Cancel it
            const requestId = 'test_id';
            provider.cancelRequest(requestId);
            
            const countAfterCancel = (provider as any)._getTotalPendingCount();
            assert.strictEqual(countAfterCancel, countWithRequest - 1);
            
            // Cleanup
            promise.catch(() => {});
        });

        it('should update badge when stored interaction status changes', async () => {
            // This verifies badge recalculation after storage updates
            const countBefore = (provider as any)._getTotalPendingCount();
            
            // Simulate canceling a stored interaction (which calls _setBadge)
            // The actual implementation would call _setBadge after updateInteraction
            (provider as any)._setBadge((provider as any)._getTotalPendingCount());
            
            // Badge should reflect the new count
            const currentBadge = mockView.badge?.value;
            if (currentBadge !== undefined) {
                assert.strictEqual(currentBadge >= 0, true);
            }
        });
    });

    describe('Regression prevention - stale badge scenarios', () => {
        it('should not show stale badge when all pending items are resolved', async () => {
            // Scenario: User had pending items, then resolved them all
            // Badge should be completely cleared, not stuck at 0
            
            (provider as any)._setBadge(0);
            
            await new Promise(resolve => setTimeout(resolve, 150));
            
            // Verify badge is removed, not stuck at 0
            const totalPending = (provider as any)._getTotalPendingCount();
            if (totalPending === 0) {
                assert.strictEqual(mockView.badge, undefined);
            }
        });

        it('should count stored interactions when in-memory requests are empty', () => {
            // Scenario: Only plan reviews/whiteboards pending, no in-memory requests
            // This was the bug - badge only checked _pendingRequests.size
            
            // Mock: no in-memory requests but 2 stored pending interactions
            const inMemoryCount = (provider as any)._pendingRequests.size;
            assert.strictEqual(inMemoryCount, 0);
            
            const totalPending = (provider as any)._getTotalPendingCount();
            // Total should include stored interactions
            // The exact value depends on what's in storage
            assert.strictEqual(totalPending >= inMemoryCount, true);
        });

        it('should immediately update badge when canceling last in-memory request with stored pending', async () => {
            // Scenario: 1 in-memory request + 1 stored plan review
            // Cancel the in-memory request
            // Badge should still show 1 (from stored), not 0 or cleared
            
            const promise = (provider as any).waitForUserResponse('Question?', 'Test');
            const countBefore = (provider as any)._getTotalPendingCount();
            
            // Cancel the request
            const requestId = 'test_id';
            provider.cancelRequest(requestId);
            
            const countAfter = (provider as any)._getTotalPendingCount();
            
            // If there are stored pending items, count should not go to 0
            if (countBefore > 1) {
                assert.strictEqual(countAfter >= 0, true);
            }
            
            // Cleanup
            promise.catch(() => {});
        });
    });
});
